#!/bin/bash
set -euo pipefail

# blatt — PDF statistics for macOS
# Usage: blatt [-v] [-r] <directory>

VERSION="0.1.0"

# --- Colors (disabled when not a TTY) ---
if [[ -t 1 ]]; then
  C_CYAN="\033[1;36m"
  C_YELLOW="\033[1;33m"
  C_GREEN="\033[1;32m"
  C_DIM="\033[0;90m"
  C_BOLD="\033[1m"
  C_WARN="\033[1;31m"
  C_RESET="\033[0m"
else
  C_CYAN="" C_YELLOW="" C_GREEN="" C_DIM="" C_BOLD="" C_WARN="" C_RESET=""
fi

# --- Defaults ---
VERBOSE=false
RECURSIVE=false
JSON=false
SORT_BY=""
TOP_N=0
TARGET_DIR=""

# --- Usage ---
usage() {
  cat <<EOF
blatt v${VERSION} — PDF statistics for a directory

Usage: blatt [-v] [-r] [--json] [--sort KEY] [--top N] [-h] <directory>

Options:
  -v              Verbose (table with per-file breakdown)
  -r              Recursive (include subdirectories)
  --json          Output as JSON
  --sort KEY      Sort verbose output by: name, pages, size (default: name)
  --top N         Show only the top N files (use with -v or --json)
  -h              Show this help

Examples:
  blatt ~/Documents
  blatt -v ~/Documents
  blatt -rv ~/Documents
  blatt --json ~/Documents
  blatt -v --sort pages ~/Documents
  blatt -v --sort size --top 5 ~/Documents
EOF
  exit 0
}

# --- Parse arguments ---
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage ;;
    --version) echo "blatt v${VERSION}"; exit 0 ;;
    -v) VERBOSE=true; shift ;;
    -r) RECURSIVE=true; shift ;;
    -rv|-vr) VERBOSE=true; RECURSIVE=true; shift ;;
    --json) JSON=true; shift ;;
    --sort)
      if [[ $# -lt 2 ]]; then
        echo "Error: --sort requires a value (name, pages, size)." >&2
        exit 1
      fi
      SORT_BY="$2"
      if [[ "$SORT_BY" != "name" && "$SORT_BY" != "pages" && "$SORT_BY" != "size" ]]; then
        echo "Error: --sort must be one of: name, pages, size." >&2
        exit 1
      fi
      shift 2
      ;;
    --top)
      if [[ $# -lt 2 ]]; then
        echo "Error: --top requires a number." >&2
        exit 1
      fi
      if ! [[ "$2" =~ ^[0-9]+$ ]] || [[ "$2" -eq 0 ]]; then
        echo "Error: --top must be a positive number." >&2
        exit 1
      fi
      TOP_N="$2"
      shift 2
      ;;
    -*)
      echo "Unknown option: $1" >&2
      echo "Use 'blatt -h' for help." >&2
      exit 1
      ;;
    *)
      if [[ -z "$TARGET_DIR" ]]; then
        TARGET_DIR="$1"
      else
        echo "Error: Only one directory allowed." >&2
        exit 1
      fi
      shift
      ;;
  esac
done

if [[ -z "$TARGET_DIR" ]]; then
  echo "Error: No directory specified." >&2
  echo "Use 'blatt -h' for help." >&2
  exit 1
fi

if [[ ! -d "$TARGET_DIR" ]]; then
  echo "Error: '${TARGET_DIR}' is not a directory." >&2
  exit 1
fi

# --- Find PDFs ---
FIND_ARGS=( "$TARGET_DIR" )
if [[ "$RECURSIVE" == false ]]; then
  FIND_ARGS+=( -maxdepth 1 )
fi
FIND_ARGS+=( -name "*.pdf" -type f )

pdf_files=()
while IFS= read -r -d '' file; do
  pdf_files+=( "$file" )
done < <(find "${FIND_ARGS[@]}" -print0 2>/dev/null | sort -z)

if [[ ${#pdf_files[@]} -eq 0 ]]; then
  echo "No PDF files found in '${TARGET_DIR}'."
  exit 0
fi

# --- Collect stats ---
total_pages=0
total_bytes=0
doc_count=0

# Arrays for verbose/JSON mode
declare -a file_names
declare -a file_pages
declare -a file_sizes
declare -a unreadable_files

for file in "${pdf_files[@]}"; do
  pages=$(mdls -name kMDItemNumberOfPages -raw "$file" 2>/dev/null)
  bytes=$(stat -f%z "$file" 2>/dev/null || echo 0)

  if [[ "$pages" == "(null)" || -z "$pages" ]]; then
    pages=0
    unreadable_files+=( "$file" )
  fi

  total_pages=$((total_pages + pages))
  total_bytes=$((total_bytes + bytes))
  doc_count=$((doc_count + 1))

  if [[ "$VERBOSE" == true || "$JSON" == true ]]; then
    file_names+=( "$file" )
    file_pages+=( "$pages" )
    file_sizes+=( "$bytes" )
  fi
done

# --- Format size ---
format_size() {
  local bytes=$1
  if (( bytes >= 1073741824 )); then
    awk "BEGIN { printf \"%.1f GB\", ${bytes}/1073741824 }"
  elif (( bytes >= 1048576 )); then
    awk "BEGIN { printf \"%.1f MB\", ${bytes}/1048576 }"
  elif (( bytes >= 1024 )); then
    awk "BEGIN { printf \"%.1f KB\", ${bytes}/1024 }"
  else
    echo "${bytes} B"
  fi
}

# --- Sort (applies to verbose and JSON) ---
if [[ -n "$SORT_BY" && ${#file_names[@]} -gt 0 ]]; then
  # Build sortable lines: "sort_key|index" then reorder arrays
  sorted_indices=()
  case "$SORT_BY" in
    name)
      while IFS= read -r line; do
        sorted_indices+=( "${line##*|}" )
      done < <(
        for i in "${!file_names[@]}"; do
          echo "$(basename "${file_names[$i]}")|$i"
        done | sort -f -t'|' -k1,1
      )
      ;;
    pages)
      while IFS= read -r line; do
        sorted_indices+=( "${line##*|}" )
      done < <(
        for i in "${!file_names[@]}"; do
          echo "${file_pages[$i]}|$i"
        done | sort -t'|' -k1,1 -n -r
      )
      ;;
    size)
      while IFS= read -r line; do
        sorted_indices+=( "${line##*|}" )
      done < <(
        for i in "${!file_names[@]}"; do
          echo "${file_sizes[$i]}|$i"
        done | sort -t'|' -k1,1 -n -r
      )
      ;;
  esac

  new_names=() new_pages=() new_sizes=()
  for i in "${sorted_indices[@]}"; do
    new_names+=( "${file_names[$i]}" )
    new_pages+=( "${file_pages[$i]}" )
    new_sizes+=( "${file_sizes[$i]}" )
  done
  file_names=( "${new_names[@]}" )
  file_pages=( "${new_pages[@]}" )
  file_sizes=( "${new_sizes[@]}" )
fi

# --- Top N (truncate displayed files, keep full totals) ---
if [[ "$TOP_N" -gt 0 && ${#file_names[@]} -gt 0 ]]; then
  file_names=( "${file_names[@]:0:$TOP_N}" )
  file_pages=( "${file_pages[@]:0:$TOP_N}" )
  file_sizes=( "${file_sizes[@]:0:$TOP_N}" )
fi

# --- JSON output ---
if [[ "$JSON" == true ]]; then
  echo "{"
  echo "  \"directory\": \"${TARGET_DIR}\","
  echo "  \"recursive\": ${RECURSIVE},"
  echo "  \"total_pages\": ${total_pages},"
  echo "  \"total_documents\": ${doc_count},"
  echo "  \"total_bytes\": ${total_bytes},"
  echo "  \"files\": ["
  for i in "${!file_names[@]}"; do
    comma=","
    [[ $i -eq $(( ${#file_names[@]} - 1 )) ]] && comma=""
    # Check if this file is unreadable
    is_unreadable=false
    for u in "${unreadable_files[@]+"${unreadable_files[@]}"}"; do
      [[ "$u" == "${file_names[$i]}" ]] && is_unreadable=true && break
    done
    echo "    {\"name\": \"$(basename "${file_names[$i]}")\", \"path\": \"${file_names[$i]}\", \"pages\": ${file_pages[$i]}, \"bytes\": ${file_sizes[$i]}, \"unreadable\": ${is_unreadable}}${comma}"
  done
  echo "  ],"
  echo "  \"unreadable_count\": ${#unreadable_files[@]}"
  echo "}"
  exit 0
fi

# --- Verbose table output ---
if [[ "$VERBOSE" == true ]]; then
  # Calculate column widths
  max_name=4  # "Name"
  for file in "${file_names[@]}"; do
    name=$(basename "$file")
    (( ${#name} > max_name )) && max_name=${#name}
  done
  # Cap name width
  (( max_name > 60 )) && max_name=60

  # Header
  printf "${C_BOLD}%-${max_name}s  %8s  %10s${C_RESET}\n" "Name" "Pages" "Size"
  printf "${C_DIM}"
  printf '%.0s─' $(seq 1 $((max_name + 22)))
  printf "${C_RESET}\n"

  # Rows
  for i in "${!file_names[@]}"; do
    name=$(basename "${file_names[$i]}")
    # Truncate long names
    if (( ${#name} > max_name )); then
      name="${name:0:$((max_name - 1))}…"
    fi
    size_str=$(format_size "${file_sizes[$i]}")
    # Mark unreadable files
    page_display="${file_pages[$i]}"
    row_color=""
    for u in "${unreadable_files[@]+"${unreadable_files[@]}"}"; do
      if [[ "$u" == "${file_names[$i]}" ]]; then
        page_display="?"
        row_color="${C_DIM}"
        break
      fi
    done
    printf "${row_color}%-${max_name}s  %8s  %10s${C_RESET}\n" "$name" "$page_display" "$size_str"
  done

  # Separator
  printf "${C_DIM}"
  printf '%.0s─' $(seq 1 $((max_name + 22)))
  printf "${C_RESET}\n"
fi

# --- Summary ---
total_size_str=$(format_size "$total_bytes")
printf "${C_CYAN}%d${C_RESET} pages in ${C_YELLOW}%d${C_RESET} documents, total size ${C_GREEN}%s${C_RESET}\n" \
  "$total_pages" "$doc_count" "$total_size_str"

# --- Unreadable warnings ---
if [[ ${#unreadable_files[@]} -gt 0 ]]; then
  printf "\n${C_WARN}Warning:${C_RESET} %d file(s) with unknown page count (not indexed or password-protected):\n" "${#unreadable_files[@]}"
  for f in "${unreadable_files[@]}"; do
    printf "  ${C_DIM}%s${C_RESET}\n" "$(basename "$f")"
  done
fi

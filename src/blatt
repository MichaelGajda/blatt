#!/bin/bash
set -euo pipefail

# blatt ‚Äî PDF statistics for macOS
# Usage: blatt [-v] [-r] <directory>

VERSION="1.3.0"

# --- Colors (disabled when not a TTY) ---
if [[ -t 1 ]]; then
  C_CYAN="\033[1;36m"
  C_YELLOW="\033[1;33m"
  C_GREEN="\033[1;32m"
  C_DIM="\033[0;90m"
  C_BOLD="\033[1m"
  C_WARN="\033[1;31m"
  C_RESET="\033[0m"
else
  C_CYAN="" C_YELLOW="" C_GREEN="" C_DIM="" C_BOLD="" C_WARN="" C_RESET=""
fi

# --- Defaults ---
VERBOSE=false
RECURSIVE=false
JSON=false
SORT_BY=""
TOP_N=0
BOX=false
FANCY=false
ULTRAFANCY=false
TARGET_DIR=""

# --- Usage ---
usage() {
  cat <<EOF
blatt v${VERSION} ‚Äî PDF statistics for a directory

Usage: blatt [-v] [-r] [--json] [--sort KEY] [--top N] [--box] [-h] <directory>

Options:
  -v              Just the facts
  -r              Recursive (include subdirectories)
  --json          Output as JSON
  --sort KEY      Sort by: name, pages, size (default: name)
  --top N         Show only the top N files
  --box           With manners
  --fancy         Dressed to impress
  --ultrafancy    You asked for this
  -h              Show this help

Examples:
  blatt ~/Documents
  blatt -v ~/Documents
  blatt -rv ~/Documents
  blatt --json ~/Documents
  blatt -v --sort pages ~/Documents
  blatt -v --sort size --top 5 ~/Documents
  blatt --box ~/Documents
  blatt --fancy ~/Documents
  blatt --ultrafancy ~/Documents
EOF
  exit 0
}

# --- Parse arguments ---
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage ;;
    --version) echo "blatt v${VERSION}"; exit 0 ;;
    -v) VERBOSE=true; shift ;;
    -r) RECURSIVE=true; shift ;;
    -rv|-vr) VERBOSE=true; RECURSIVE=true; shift ;;
    --json) JSON=true; shift ;;
    --sort)
      if [[ $# -lt 2 ]]; then
        echo "Error: --sort requires a value (name, pages, size)." >&2
        exit 1
      fi
      SORT_BY="$2"
      if [[ "$SORT_BY" != "name" && "$SORT_BY" != "pages" && "$SORT_BY" != "size" ]]; then
        echo "Error: --sort must be one of: name, pages, size." >&2
        exit 1
      fi
      shift 2
      ;;
    --top)
      if [[ $# -lt 2 ]]; then
        echo "Error: --top requires a number." >&2
        exit 1
      fi
      if ! [[ "$2" =~ ^[0-9]+$ ]] || [[ "$2" -eq 0 ]]; then
        echo "Error: --top must be a positive number." >&2
        exit 1
      fi
      TOP_N="$2"
      shift 2
      ;;
    --box) BOX=true; VERBOSE=true; shift ;;
    --fancy) FANCY=true; BOX=true; VERBOSE=true; shift ;;
    --ultrafancy) ULTRAFANCY=true; FANCY=true; BOX=true; VERBOSE=true; shift ;;
    -*)
      echo "Unknown option: $1" >&2
      echo "Use 'blatt -h' for help." >&2
      exit 1
      ;;
    *)
      if [[ -z "$TARGET_DIR" ]]; then
        TARGET_DIR="$1"
      else
        echo "Error: Only one directory allowed." >&2
        exit 1
      fi
      shift
      ;;
  esac
done

if [[ -z "$TARGET_DIR" ]]; then
  echo "Error: No directory specified." >&2
  echo "Use 'blatt -h' for help." >&2
  exit 1
fi

if [[ ! -d "$TARGET_DIR" ]]; then
  echo "Error: '${TARGET_DIR}' is not a directory." >&2
  exit 1
fi

# --- Find PDFs ---
FIND_ARGS=( "$TARGET_DIR" )
if [[ "$RECURSIVE" == false ]]; then
  FIND_ARGS+=( -maxdepth 1 )
fi
FIND_ARGS+=( -name "*.pdf" -type f )

pdf_files=()
while IFS= read -r -d '' file; do
  pdf_files+=( "$file" )
done < <(find "${FIND_ARGS[@]}" -print0 2>/dev/null | sort -z)

if [[ ${#pdf_files[@]} -eq 0 ]]; then
  echo "No PDF files found in '${TARGET_DIR}'."
  exit 0
fi

# --- Collect stats ---
total_pages=0
total_bytes=0
doc_count=0

# Arrays for verbose/JSON mode
declare -a file_names
declare -a file_pages
declare -a file_sizes
declare -a unreadable_files

for file in "${pdf_files[@]}"; do
  pages=$(mdls -name kMDItemNumberOfPages -raw "$file" 2>/dev/null)
  bytes=$(stat -f%z "$file" 2>/dev/null || echo 0)

  if [[ "$pages" == "(null)" || -z "$pages" ]]; then
    pages=0
    unreadable_files+=( "$file" )
  fi

  total_pages=$((total_pages + pages))
  total_bytes=$((total_bytes + bytes))
  doc_count=$((doc_count + 1))

  if [[ "$VERBOSE" == true || "$JSON" == true ]]; then
    file_names+=( "$file" )
    file_pages+=( "$pages" )
    file_sizes+=( "$bytes" )
  fi
done

# --- Format size ---
format_size() {
  local bytes=$1
  if (( bytes >= 1073741824 )); then
    awk "BEGIN { printf \"%.1f GB\", ${bytes}/1073741824 }"
  elif (( bytes >= 1048576 )); then
    awk "BEGIN { printf \"%.1f MB\", ${bytes}/1048576 }"
  elif (( bytes >= 1024 )); then
    awk "BEGIN { printf \"%.1f KB\", ${bytes}/1024 }"
  else
    echo "${bytes} B"
  fi
}

# --- Display width helper (handles combining characters from macOS NFD) ---
display_width() {
  # Convert NFD (macOS) to NFC, then count characters for true display width
  printf '%s' "$1" | iconv -f utf-8-mac -t utf-8 | wc -m | tr -d ' '
}

# --- Manual padding (printf %-Ns can't handle combining chars correctly) ---
pad_right() {
  local str="$1" target_width="$2"
  local dw
  dw=$(display_width "$str")
  local spaces=$(( target_width - dw ))
  printf '%s' "$str"
  if [[ "$spaces" -gt 0 ]]; then printf "%${spaces}s" ""; fi
}

# --- Fancy color helpers ---
color_for_pages() {
  local pages=$1
  if (( pages == 0 )); then echo "${C_DIM}"
  elif (( pages < 20 )); then echo "${C_GREEN}"
  elif (( pages < 100 )); then echo "${C_YELLOW}"
  else echo "${C_WARN}"
  fi
}

color_for_bytes() {
  local bytes=$1
  if (( bytes < 1048576 )); then echo "${C_GREEN}"        # < 1 MB
  elif (( bytes < 10485760 )); then echo "${C_YELLOW}"     # < 10 MB
  else echo "${C_WARN}"                                     # >= 10 MB
  fi
}

# --- Sparkline bar ---
sparkline() {
  local value=$1 max=$2 width=${3:-10}
  if (( max == 0 )); then echo ""; return; fi
  local filled=$(( value * width / max ))
  (( filled == 0 && value > 0 )) && filled=1
  local bar=""
  for (( j=0; j<filled; j++ )); do bar+="‚ñà"; done
  for (( j=filled; j<width; j++ )); do bar+="‚ñë"; done
  echo "$bar"
}

# --- Ultrafancy helpers ---
random_signoff() {
  local phrases=(
    "Powered by a developer who really needed to count pages"
    "No trees were counted in the making of this"
    "Blatt: German for leaf, page, and overkill"
    "Your PDFs called. They feel measured."
    "This tool is more extra than your PDF collection"
    "Sponsored by whoever invented the PDF in 1993"
    "Fun fact: you just mass-surveilled your own files"
    "Blatt says: go paperless, but keep the PDFs"
  )
  echo "${phrases[$((RANDOM % ${#phrases[@]}))]}"
}

animated_rainbow() {
  local text="$1" cycles="${2:-20}"
  local colors=(196 208 220 46 51 171)  # red orange yellow green cyan purple
  local num_colors=${#colors[@]}
  # Hide cursor
  printf "\033[?25l"
  for (( frame=0; frame<cycles; frame++ )); do
    printf "\r  "
    local ci=0
    for (( c=0; c<${#text}; c++ )); do
      local char="${text:$c:1}"
      if [[ "$char" == " " ]]; then
        printf " "
      else
        local color_idx=$(( (ci + frame) % num_colors ))
        printf "\033[38;5;%dm%s" "${colors[$color_idx]}" "$char"
        ((ci++))
      fi
    done
    sleep 0.08
  done
  printf "${C_RESET}"
  # Show cursor
  printf "\033[?25h"
}

type_text() {
  local text="$1" delay="${2:-0.02}"
  local i=0 char
  while IFS= read -r -n1 char; do
    printf "%s" "$char"
    sleep "$delay"
  done <<< "$text"
}

scanning_animation() {
  local leaves=("üçÇ" "üçÅ" "üçÉ" "üåø" "üçÇ")
  printf "\n"
  for i in 1 2 3; do
    for leaf in "${leaves[@]}"; do
      printf "\r  ${C_DIM}Counting pages...${C_RESET} %s " "$leaf"
      sleep 0.08
    done
  done
  printf "\r  ${C_GREEN}Done!${C_RESET} Found ${C_CYAN}%d${C_RESET} documents.           \n\n" "$doc_count"
  sleep 0.3
}

# --- Sort (applies to verbose and JSON) ---
if [[ -n "$SORT_BY" && ${#file_names[@]} -gt 0 ]]; then
  # Build sortable lines: "sort_key|index" then reorder arrays
  sorted_indices=()
  case "$SORT_BY" in
    name)
      while IFS= read -r line; do
        sorted_indices+=( "${line##*|}" )
      done < <(
        for i in "${!file_names[@]}"; do
          echo "$(basename "${file_names[$i]}")|$i"
        done | sort -f -t'|' -k1,1
      )
      ;;
    pages)
      while IFS= read -r line; do
        sorted_indices+=( "${line##*|}" )
      done < <(
        for i in "${!file_names[@]}"; do
          echo "${file_pages[$i]}|$i"
        done | sort -t'|' -k1,1 -n -r
      )
      ;;
    size)
      while IFS= read -r line; do
        sorted_indices+=( "${line##*|}" )
      done < <(
        for i in "${!file_names[@]}"; do
          echo "${file_sizes[$i]}|$i"
        done | sort -t'|' -k1,1 -n -r
      )
      ;;
  esac

  new_names=() new_pages=() new_sizes=()
  for i in "${sorted_indices[@]}"; do
    new_names+=( "${file_names[$i]}" )
    new_pages+=( "${file_pages[$i]}" )
    new_sizes+=( "${file_sizes[$i]}" )
  done
  file_names=( "${new_names[@]}" )
  file_pages=( "${new_pages[@]}" )
  file_sizes=( "${new_sizes[@]}" )
fi

# --- Top N (truncate displayed files, keep full totals) ---
if [[ "$TOP_N" -gt 0 && ${#file_names[@]} -gt 0 ]]; then
  file_names=( "${file_names[@]:0:$TOP_N}" )
  file_pages=( "${file_pages[@]:0:$TOP_N}" )
  file_sizes=( "${file_sizes[@]:0:$TOP_N}" )
fi

# --- JSON output ---
if [[ "$JSON" == true ]]; then
  echo "{"
  echo "  \"version\": \"${VERSION}\","
  echo "  \"directory\": \"${TARGET_DIR}\","
  echo "  \"recursive\": ${RECURSIVE},"
  echo "  \"total_pages\": ${total_pages},"
  echo "  \"total_documents\": ${doc_count},"
  echo "  \"total_bytes\": ${total_bytes},"
  echo "  \"files\": ["
  for i in "${!file_names[@]}"; do
    comma=","
    [[ $i -eq $(( ${#file_names[@]} - 1 )) ]] && comma=""
    # Check if this file is unreadable
    is_unreadable=false
    for u in "${unreadable_files[@]+"${unreadable_files[@]}"}"; do
      [[ "$u" == "${file_names[$i]}" ]] && is_unreadable=true && break
    done
    echo "    {\"name\": \"$(basename "${file_names[$i]}")\", \"path\": \"${file_names[$i]}\", \"pages\": ${file_pages[$i]}, \"bytes\": ${file_sizes[$i]}, \"unreadable\": ${is_unreadable}}${comma}"
  done
  echo "  ],"
  echo "  \"unreadable_count\": ${#unreadable_files[@]}"
  echo "}"
  exit 0
fi

# --- Verbose table output ---
if [[ "$VERBOSE" == true ]]; then
  # Calculate column widths (use display width to handle combining chars)
  max_name=5  # "Total"
  for file in "${file_names[@]}"; do
    name=$(basename "$file")
    dw=$(display_width "$name")
    (( dw > max_name )) && max_name=$dw
  done
  # Cap name width
  (( max_name > 60 )) && max_name=60

  col_w=$((max_name + 8 + 10 + 4))  # name + pages + size + spacing
  total_size_str=$(format_size "$total_bytes")

  # Find max bytes for sparkline scaling
  max_bytes=0
  for b in "${file_sizes[@]}"; do
    (( b > max_bytes )) && max_bytes=$b
  done

  if [[ "$BOX" == true ]]; then
    # Ultrafancy: scanning animation
    if [[ "$ULTRAFANCY" == true ]]; then
      scanning_animation
    fi

    # Extra column for sparkline in ultrafancy
    spark_w=12
    if [[ "$ULTRAFANCY" == true ]]; then
      printf "‚îå‚îÄ"; printf '%.0s‚îÄ' $(seq 1 $max_name); printf "‚îÄ‚î¨‚îÄ"; printf '%.0s‚îÄ' $(seq 1 8); printf "‚îÄ‚î¨‚îÄ"; printf '%.0s‚îÄ' $(seq 1 10); printf "‚îÄ‚î¨‚îÄ"; printf '%.0s‚îÄ' $(seq 1 $spark_w); printf "‚îÄ‚îê\n"
    else
      printf "‚îå‚îÄ"; printf '%.0s‚îÄ' $(seq 1 $max_name); printf "‚îÄ‚î¨‚îÄ"; printf '%.0s‚îÄ' $(seq 1 8); printf "‚îÄ‚î¨‚îÄ"; printf '%.0s‚îÄ' $(seq 1 10); printf "‚îÄ‚îê\n"
    fi

    # Header
    if [[ "$FANCY" == true ]]; then
      # Header with background color
      hdr_bg="\033[48;5;236m"
      if [[ "$ULTRAFANCY" == true ]]; then
        printf "‚îÇ ${hdr_bg}${C_BOLD}%-${max_name}s${C_RESET} ‚îÇ ${hdr_bg}${C_BOLD}%8s${C_RESET} ‚îÇ ${hdr_bg}${C_BOLD}%10s${C_RESET} ‚îÇ ${hdr_bg}${C_BOLD}%-${spark_w}s${C_RESET} ‚îÇ\n" "Name" "Pages" "Size" "Scale"
      else
        printf "‚îÇ ${hdr_bg}${C_BOLD}%-${max_name}s${C_RESET} ‚îÇ ${hdr_bg}${C_BOLD}%8s${C_RESET} ‚îÇ ${hdr_bg}${C_BOLD}%10s${C_RESET} ‚îÇ\n" "Name" "Pages" "Size"
      fi
    else
      printf "‚îÇ ${C_BOLD}%-${max_name}s${C_RESET} ‚îÇ ${C_BOLD}%8s${C_RESET} ‚îÇ ${C_BOLD}%10s${C_RESET} ‚îÇ\n" "Name" "Pages" "Size"
    fi

    if [[ "$ULTRAFANCY" == true ]]; then
      printf "‚îú‚îÄ"; printf '%.0s‚îÄ' $(seq 1 $max_name); printf "‚îÄ‚îº‚îÄ"; printf '%.0s‚îÄ' $(seq 1 8); printf "‚îÄ‚îº‚îÄ"; printf '%.0s‚îÄ' $(seq 1 10); printf "‚îÄ‚îº‚îÄ"; printf '%.0s‚îÄ' $(seq 1 $spark_w); printf "‚îÄ‚î§\n"
    else
      printf "‚îú‚îÄ"; printf '%.0s‚îÄ' $(seq 1 $max_name); printf "‚îÄ‚îº‚îÄ"; printf '%.0s‚îÄ' $(seq 1 8); printf "‚îÄ‚îº‚îÄ"; printf '%.0s‚îÄ' $(seq 1 10); printf "‚îÄ‚î§\n"
    fi

    for i in "${!file_names[@]}"; do
      name=$(basename "${file_names[$i]}")
      if (( ${#name} > max_name )); then
        name="${name:0:$((max_name - 1))}‚Ä¶"
      fi
      size_str=$(format_size "${file_sizes[$i]}")
      page_display="${file_pages[$i]}"

      # Determine colors
      is_unreadable=false
      for u in "${unreadable_files[@]+"${unreadable_files[@]}"}"; do
        [[ "$u" == "${file_names[$i]}" ]] && is_unreadable=true && break
      done

      if [[ "$is_unreadable" == true ]]; then
        page_display="?"
        pc="${C_DIM}"; sc="${C_DIM}"; nc="${C_DIM}"
      elif [[ "$FANCY" == true ]]; then
        pc=$(color_for_pages "${file_pages[$i]}")
        sc=$(color_for_bytes "${file_sizes[$i]}")
        nc=""
        # Alternating row dim
        if (( i % 2 == 1 )); then nc="\033[48;5;234m"; fi
      else
        pc=""; sc=""; nc=""
      fi

      padded_name=$(pad_right "$name" "$max_name")
      padded_pages=$(printf "%8s" "$page_display")
      padded_size=$(printf "%10s" "$size_str")
      if [[ "$ULTRAFANCY" == true ]]; then
        bar=$(sparkline "${file_sizes[$i]}" "$max_bytes" "$spark_w")
        row_str=""
        row_str=$(printf "‚îÇ ${nc}%s${C_RESET} ‚îÇ ${nc}${pc}%s${C_RESET} ‚îÇ ${nc}${sc}%s${C_RESET} ‚îÇ ${C_DIM}%-${spark_w}s${C_RESET} ‚îÇ" "$padded_name" "$padded_pages" "$padded_size" "$bar")
        type_text "$row_str" 0.005
        printf "\n"
        sleep 0.05
      else
        printf "‚îÇ ${nc}%s${C_RESET} ‚îÇ ${nc}${pc}%s${C_RESET} ‚îÇ ${nc}${sc}%s${C_RESET} ‚îÇ\n" "$padded_name" "$padded_pages" "$padded_size"
      fi
    done

    # Totals separator
    if [[ "$ULTRAFANCY" == true ]]; then
      printf "‚îú‚îÄ"; printf '%.0s‚îÄ' $(seq 1 $max_name); printf "‚îÄ‚îº‚îÄ"; printf '%.0s‚îÄ' $(seq 1 8); printf "‚îÄ‚îº‚îÄ"; printf '%.0s‚îÄ' $(seq 1 10); printf "‚îÄ‚îº‚îÄ"; printf '%.0s‚îÄ' $(seq 1 $spark_w); printf "‚îÄ‚î§\n"
      # „ÉÑ is double-width, so manually pad to align the box border
      shrug="¬Ø\_(„ÉÑ)_/¬Ø"
      pad=$((spark_w - 10))  # 10 = display width of shrug (9 chars + 1 extra for wide „ÉÑ)
      shrug_padded="${shrug}$(printf '%*s' "$pad" "")"
      printf "‚îÇ ${C_BOLD}%-${max_name}s${C_RESET} ‚îÇ ${C_CYAN}%8d${C_RESET} ‚îÇ ${C_GREEN}%10s${C_RESET} ‚îÇ %s ‚îÇ\n" "${doc_count} docs" "$total_pages" "$total_size_str" "$shrug_padded"
      printf "‚îî‚îÄ"; printf '%.0s‚îÄ' $(seq 1 $max_name); printf "‚îÄ‚î¥‚îÄ"; printf '%.0s‚îÄ' $(seq 1 8); printf "‚îÄ‚î¥‚îÄ"; printf '%.0s‚îÄ' $(seq 1 10); printf "‚îÄ‚î¥‚îÄ"; printf '%.0s‚îÄ' $(seq 1 $spark_w); printf "‚îÄ‚îò\n"
    else
      printf "‚îú‚îÄ"; printf '%.0s‚îÄ' $(seq 1 $max_name); printf "‚îÄ‚îº‚îÄ"; printf '%.0s‚îÄ' $(seq 1 8); printf "‚îÄ‚îº‚îÄ"; printf '%.0s‚îÄ' $(seq 1 10); printf "‚îÄ‚î§\n"
      printf "‚îÇ ${C_BOLD}%-${max_name}s${C_RESET} ‚îÇ ${C_CYAN}%8d${C_RESET} ‚îÇ ${C_GREEN}%10s${C_RESET} ‚îÇ\n" "${doc_count} docs" "$total_pages" "$total_size_str"
      printf "‚îî‚îÄ"; printf '%.0s‚îÄ' $(seq 1 $max_name); printf "‚îÄ‚î¥‚îÄ"; printf '%.0s‚îÄ' $(seq 1 8); printf "‚îÄ‚î¥‚îÄ"; printf '%.0s‚îÄ' $(seq 1 10); printf "‚îÄ‚îò\n"
    fi

    # Ultrafancy sign-off
    if [[ "$ULTRAFANCY" == true ]]; then
      signoff=$(random_signoff)
      printf "\n"
      animated_rainbow "$signoff" 24
      printf "\n"
    fi
  else
    # Default style
    printf "${C_BOLD}%-${max_name}s  %8s  %10s${C_RESET}\n" "Name" "Pages" "Size"
    printf "${C_DIM}"; printf '%.0s‚îÄ' $(seq 1 $col_w); printf "${C_RESET}\n"

    for i in "${!file_names[@]}"; do
      name=$(basename "${file_names[$i]}")
      if (( ${#name} > max_name )); then
        name="${name:0:$((max_name - 1))}‚Ä¶"
      fi
      size_str=$(format_size "${file_sizes[$i]}")
      page_display="${file_pages[$i]}"
      row_color=""
      for u in "${unreadable_files[@]+"${unreadable_files[@]}"}"; do
        if [[ "$u" == "${file_names[$i]}" ]]; then
          page_display="?"
          row_color="${C_DIM}"
          break
        fi
      done
      padded_name=$(pad_right "$name" "$max_name")
      printf "${row_color}%s  %8s  %10s${C_RESET}\n" "$padded_name" "$page_display" "$size_str"
    done

    printf "${C_DIM}"; printf '%.0s‚îÄ' $(seq 1 $col_w); printf "${C_RESET}\n"
    printf "${C_BOLD}%-${max_name}s${C_RESET}  ${C_CYAN}%8d${C_RESET}  ${C_GREEN}%10s${C_RESET}\n" "${doc_count} docs" "$total_pages" "$total_size_str"
  fi
fi

# --- Summary ---
total_size_str=$(format_size "$total_bytes")
if [[ "$VERBOSE" != true ]]; then
  printf "${C_CYAN}%d${C_RESET} pages in ${C_YELLOW}%d${C_RESET} documents, total size ${C_GREEN}%s${C_RESET}\n" \
    "$total_pages" "$doc_count" "$total_size_str"
fi

# --- Unreadable notes ---
if [[ ${#unreadable_files[@]} -gt 0 ]]; then
  unreadable_names=()
  for f in "${unreadable_files[@]}"; do
    unreadable_names+=( "$(basename "$f")" )
  done
  joined=$(IFS=", "; echo "${unreadable_names[*]}")

  if [[ "$ULTRAFANCY" == true ]]; then
    amber="\033[38;5;214m"
    printf "\n  üëÄ ${amber}Psst ‚Äî %d file(s) being mysterious about their page count${C_RESET}\n" "${#unreadable_files[@]}"
    printf "  ${C_DIM}   (not indexed or password-protected)${C_RESET}\n"
    for name in "${unreadable_names[@]}"; do
      printf "  ${C_DIM}   ‚Üí %s${C_RESET}\n" "$name"
    done
  elif [[ "$FANCY" == true ]]; then
    printf "\n  ${C_DIM}‚Ñπ %d file(s) with unknown page count${C_RESET}\n" "${#unreadable_files[@]}"
    printf "  ${C_DIM}  (not indexed or password-protected)${C_RESET}\n"
    for name in "${unreadable_names[@]}"; do
      printf "  ${C_DIM}  ‚Üí %s${C_RESET}\n" "$name"
    done
  else
    printf "\n  ${C_DIM}‚Ñπ %d file(s) with unknown page count${C_RESET}\n" "${#unreadable_files[@]}"
    printf "  ${C_DIM}  (not indexed or password-protected)${C_RESET}\n"
    for name in "${unreadable_names[@]}"; do
      printf "  ${C_DIM}  ‚Üí %s${C_RESET}\n" "$name"
    done
  fi
fi
